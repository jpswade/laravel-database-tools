parameters:
	ignoreErrors:
		# spatie/db-dumper 3.x returns DbDumper from chained setters where 4.x
		# returns static (MySql). When CI resolves db-dumper 3.x for older PHP
		# cells, PHPStan loses sight of the MySql-only skipLockTables(). The
		# call is correct at runtime regardless. reportUnmatchedIgnoredErrors
		# is disabled in phpstan.neon.dist so this entry is tolerated on cells
		# that resolve db-dumper 4.x.
		-
			message: '#^Call to an undefined method Spatie\\DbDumper\\DbDumper\:\:skipLockTables\(\)\.$#'
			identifier: method.notFound
			count: 1
			path: src/Commands/DatabaseDumpCommand.php
