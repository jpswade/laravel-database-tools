{
    "name": "jpswade/laravel-database-tools",
    "description": "Laravel Database Tools",
    "keywords": [
        "laravel",
        "database",
        "db",
        "sqlite",
        "tools",
        "backup"
    ],
    "type": "laravel-package",
    "license": "MIT",
    "authors": [
        {
            "name": "James Wade",
            "email": "jpswade@gmail.com"
        }
    ],
    "require": {
        "php": "^7.4|^8.0|^8.1|^8.2|^8.3|^8.4|^8.5",
        "illuminate/support": "*",
        "illuminate/console": "*",
        "illuminate/filesystem": "*",
        "laravel/framework": "8.*|9.*|10.*|11.*|12.*|13.*",
        "ext-fileinfo": "*",
        "ext-pdo": "*",
        "ext-zip": "*"
    },
    "require-dev": {
        "orchestra/testbench": "*",
        "squizlabs/php_codesniffer": "*",
        "spatie/db-dumper": "*",
        "laravel/boost": "^2.0",
        "jpswade/laravel-best-practices": "dev-main",
        "larastan/larastan": "^3.0",
        "phpstan/phpstan-strict-rules": "^2.0"
    },
    "autoload": {
        "psr-4": {
            "Jpswade\\LaravelDatabaseTools\\": "src"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Jpswade\\LaravelDatabaseTools\\Tests\\": "tests"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Jpswade\\LaravelDatabaseTools\\ServiceProvider"
            ]
        }
    },
    "suggest": {
        "league/flysystem-aws-s3-v3": "Needed for db:getFromBackup command to use the S3 Driver.",
        "spatie/db-dumper": "Needed by the db:dump command."
    },
    "scripts": {
        "phpcs": [
            "./vendor/bin/phpcs --standard=phpcs.xml"
        ],
        "phpcbf": [
            "./vendor/bin/phpcbf --standard=phpcs.xml"
        ],
        "phpcs-baseline": [
            "./vendor/bin/phpcs --standard=phpcs.xml --report=json > phpcs-baseline.json"
        ],
        "phpunit": [
            "./vendor/bin/phpunit"
        ],
        "phpstan": [
            "./vendor/bin/phpstan analyse --memory-limit=-1"
        ],
        "test": [
            "@phpcs",
            "@phpstan",
            "@phpunit"
        ]
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
