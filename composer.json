{
    "name": "jpswade/laravel-database-tools",
    "description": "Laravel Database Tools",
    "keywords": [
        "laravel",
        "database",
        "db",
        "sqlite",
        "tools",
        "backup"
    ],
    "type": "laravel-package",
    "license": "MIT",
    "authors": [
        {
            "name": "James Wade",
            "email": "jpswade@gmail.com"
        }
    ],
    "require": {
        "php": "^8.1|^8.2|^8.3|^8.4|^8.5",
        "illuminate/support": "^10.0|^11.0|^12.0|^13.0",
        "illuminate/console": "^10.0|^11.0|^12.0|^13.0",
        "illuminate/filesystem": "^10.0|^11.0|^12.0|^13.0",
        "laravel/framework": "^10.0|^11.0|^12.0|^13.0",
        "ext-fileinfo": "*",
        "ext-pdo": "*",
        "ext-zip": "*"
    },
    "require-dev": {
        "orchestra/testbench": "*",
        "laravel/pint": "^1.27",
        "spatie/db-dumper": "^3.8 || ^4.0",
        "laravel/boost": "^2.0",
        "jpswade/laravel-best-practices": "dev-main",
        "larastan/larastan": "^3.0",
        "phpstan/phpstan-strict-rules": "^2.0"
    },
    "autoload": {
        "psr-4": {
            "Jpswade\\LaravelDatabaseTools\\": "src"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Jpswade\\LaravelDatabaseTools\\Tests\\": "tests"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Jpswade\\LaravelDatabaseTools\\ServiceProvider"
            ]
        }
    },
    "suggest": {
        "league/flysystem-aws-s3-v3": "Needed for db:getFromBackup command to use the S3 Driver.",
        "spatie/db-dumper": "Needed by the db:dump command."
    },
    "scripts": {
        "pint": [
            "./vendor/bin/pint"
        ],
        "pint-test": [
            "./vendor/bin/pint --test"
        ],
        "phpunit": [
            "./vendor/bin/phpunit"
        ],
        "phpstan": [
            "./vendor/bin/phpstan analyse --memory-limit=-1"
        ],
        "test": [
            "@pint-test",
            "@phpstan",
            "@phpunit"
        ]
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
